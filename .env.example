# Copy to .env locally for overrides. Never commit service-role, secret, JWT,
# database, SMTP, Stripe, or webhook keys. Supabase publishable keys are
# client configuration and are safe for the iOS app when RLS is enforced.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=replace-with-local-or-project-publishable-key

# Legacy fallback supported by the app while we migrate naming.
SUPABASE_ANON_KEY=replace-with-local-or-project-anon-key
